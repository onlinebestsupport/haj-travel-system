    <!-- Session Warning Banner -->
    <div id="sessionWarning" onclick="extendSession()">
        <i class="fas fa-exclamation-triangle"></i> 
        <span id="sessionWarningMessage">Your session will expire in 2 minutes. Click to extend.</span>
    </div>

    <!-- Notification -->
    <div id="notification" class="notification"></div>

    <!-- Session Manager Script (Create this file at /admin/js/session-manager.js) -->
    <script>
        // Session Manager - Centralized authentication handling
        const SessionManager = {
            // Check session and redirect if not authenticated
            initPage: async function(callback) {
                try {
                    const session = await this.checkSession();
                    
                    if (!session.authenticated) {
                        console.log('⚠️ Not logged in, redirecting to login...');
                        window.location.href = '/admin.login.html';
                        return false;
                    }
                    
                    // Update UI with user info
                    this.updateUI(session);
                    
                    // Execute page-specific callback
                    if (callback && typeof callback === 'function') {
                        await callback();
                    }
                    
                    return true;
                } catch (error) {
                    console.error('Session initialization failed:', error);
                    window.location.href = '/admin.login.html';
                    return false;
                }
            },

            // Check session with backend
            checkSession: async function() {
                const response = await fetch('/api/check-session', {
                    credentials: 'include',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                
                if (!response.ok) {
                    throw new Error('Session check failed');
                }
                
                return await response.json();
            },

            // Update UI based on session data
            updateUI: function(session) {
                // Update role badge if it exists
                const roleBadge = document.getElementById('roleBadge');
                if (roleBadge) {
                    roleBadge.textContent = session.role || 'Admin';
                }
                
                // Store session data if needed
                if (session.authenticated) {
                    sessionStorage.setItem('userRole', session.role || 'Admin');
                    sessionStorage.setItem('username', session.username || '');
                    sessionStorage.setItem('adminLoggedIn', 'true');
                }
            },

            // Logout function
            logout: async function() {
                try {
                    const response = await fetch('/api/logout', {
                        method: 'POST',
                        credentials: 'include',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });
                    
                    // Clear session storage
                    sessionStorage.removeItem('userRole');
                    sessionStorage.removeItem('username');
                    sessionStorage.removeItem('adminLoggedIn');
                    
                    // Redirect to login
                    window.location.href = '/admin.login.html';
                    
                } catch (error) {
                    console.error('Logout error:', error);
                    // Still redirect even if logout fails
                    window.location.href = '/admin.login.html';
                }
            },

            // Get current session data from storage
            getCurrentUser: function() {
                return {
                    role: sessionStorage.getItem('userRole'),
                    username: sessionStorage.getItem('username')
                };
            },

            // Check if user is authenticated (client-side)
            isAuthenticated: function() {
                return !!sessionStorage.getItem('adminLoggedIn');
            }
        };
    </script>

    <!-- Main Dashboard Script -->
    <script>
        // ==================== OPTIMIZED JAVASCRIPT WITH FIXES ====================
        
        // Use strict mode to catch errors
        'use strict';

        // ==================== GLOBAL VARIABLES ====================
        let chartInstances = {
            paymentsChart: null,
            travelersChart: null
        };
        
        let intervals = [];
        let sessionWarningTimeout = null;
        let sessionLogoutTimeout = null;
        let warningShown = false;
        let notificationTimeout = null;

        // ==================== PAGE INITIALIZATION ====================
        document.addEventListener('DOMContentLoaded', async function() {
            try {
                // Initialize with SessionManager
                await SessionManager.initPage(initializeDashboard);
            } catch (error) {
                console.error('Failed to initialize dashboard:', error);
                showNotification('Failed to load dashboard', 'error');
            }
        });

        // Dashboard initialization function (called after auth check)
        async function initializeDashboard() {
            console.log('✅ User authenticated, loading dashboard...');
            
            // Update UI with user info from session
            updateUserInterface();
            
            // Initialize session management
            resetSessionTimer();
            
            // Monitor user activity
            ['click', 'mousemove', 'keypress', 'scroll', 'touchstart'].forEach(event => {
                document.addEventListener(event, resetSessionTimer);
            });
            
            // Load dashboard data
            await loadDashboardStats();
            updateDateTime();
            await loadRecentActivity();
            
            // Initialize charts after Chart.js loads
            if (typeof Chart !== 'undefined') {
                initializeCharts();
            } else {
                // Wait for Chart.js to load
                const checkChart = setInterval(() => {
                    if (typeof Chart !== 'undefined') {
                        clearInterval(checkChart);
                        initializeCharts();
                    }
                }, 100);
                intervals.push(checkChart);
            }
            
            // Update time every second (optimized with requestAnimationFrame)
            const timeInterval = setInterval(() => {
                if (!document.hidden) {
                    window.requestAnimationFrame(updateDateTime);
                }
            }, 1000);
            intervals.push(timeInterval);
            
            // Handle visibility change
            document.addEventListener('visibilitychange', function() {
                if (!document.hidden) {
                    loadDashboardStats();
                    loadRecentActivity();
                }
            });
        }

        // Update UI with user info from session
        function updateUserInterface() {
            try {
                const user = SessionManager.getCurrentUser();
                const userName = user.username || 'Admin';
                const userRole = user.role || 'admin';
                
                const greetingName = document.getElementById('greetingName');
                const userDisplayName = document.getElementById('userDisplayName');
                const userRoleDisplay = document.getElementById('userRoleDisplay');
                const userAvatar = document.getElementById('userAvatar');
                
                if (greetingName) greetingName.textContent = userName;
                if (userDisplayName) userDisplayName.textContent = userName;
                if (userRoleDisplay) userRoleDisplay.textContent = formatRole(userRole);
                
                // Set avatar initials
                if (userAvatar) {
                    const nameParts = userName.split(' ');
                    let initials = '';
                    for (let i = 0; i < Math.min(2, nameParts.length); i++) {
                        if (nameParts[i] && nameParts[i].length > 0) {
                            initials += nameParts[i][0].toUpperCase();
                        }
                    }
                    userAvatar.textContent = initials || 'AD';
                }
                
                // Update role badge in sidebar if exists
                const roleBadge = document.getElementById('roleBadge');
                if (roleBadge) {
                    roleBadge.textContent = formatRole(userRole);
                }
            } catch (e) {
                console.error('Error updating user interface:', e);
            }
        }

        // ==================== SESSION MANAGEMENT ====================
        function resetSessionTimer() {
            if (sessionWarningTimeout) clearTimeout(sessionWarningTimeout);
            if (sessionLogoutTimeout) clearTimeout(sessionLogoutTimeout);
            
            hideSessionWarning();
            
            // Show warning after 25 minutes (1500000 ms)
            sessionWarningTimeout = setTimeout(showSessionWarning, 1500000);
            
            // Auto logout after 30 minutes (1800000 ms)
            sessionLogoutTimeout = setTimeout(showSessionExpiredWarning, 1800000);
        }

        function showSessionWarning() {
            if (warningShown) return;
            
            const warning = document.getElementById('sessionWarning');
            const message = document.getElementById('sessionWarningMessage');
            if (!warning || !message) return;
            
            message.textContent = 'Your session will expire in 2 minutes. Click to extend.';
            warning.style.display = 'block';
            warningShown = true;
        }

        function hideSessionWarning() {
            const warning = document.getElementById('sessionWarning');
            if (warning) {
                warning.style.display = 'none';
            }
            warningShown = false;
        }

        function showSessionExpiredWarning() {
            hideSessionWarning();
            showNotification('Your session has expired. Redirecting to login...', 'warning');
            
            setTimeout(() => {
                window.location.href = '/admin.login.html';
            }, 3000);
        }

        async function extendSession() {
            try {
                await SessionManager.checkSession();
                hideSessionWarning();
                resetSessionTimer();
                showNotification('Session extended successfully', 'success');
            } catch (error) {
                console.error('Session extension failed:', error);
                showSessionExpiredWarning();
            }
        }

        // ==================== CLEANUP ====================
        window.addEventListener('beforeunload', function() {
            intervals.forEach(interval => clearInterval(interval));
            
            if (sessionWarningTimeout) clearTimeout(sessionWarningTimeout);
            if (sessionLogoutTimeout) clearTimeout(sessionLogoutTimeout);
            if (notificationTimeout) clearTimeout(notificationTimeout);
            
            // Destroy chart instances
            Object.values(chartInstances).forEach(chart => {
                if (chart && typeof chart.destroy === 'function') {
                    try {
                        chart.destroy();
                    } catch (e) {}
                }
            });
        });

        // ==================== DATE/TIME ====================
        function updateDateTime() {
            try {
                const now = new Date();
                
                const dateOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
                const timeOptions = { hour: '2-digit', minute: '2-digit', second: '2-digit' };
                const headerDateOptions = { weekday: 'short', month: 'short', day: 'numeric' };
                const headerTimeOptions = { hour: '2-digit', minute: '2-digit' };
                
                const currentDate = document.getElementById('currentDate');
                const currentTime = document.getElementById('currentTime');
                const headerDate = document.getElementById('headerDate');
                const headerTime = document.getElementById('headerTime');
                
                if (currentDate) currentDate.textContent = now.toLocaleDateString('en-US', dateOptions);
                if (currentTime) currentTime.textContent = now.toLocaleTimeString('en-US', timeOptions);
                if (headerDate) headerDate.textContent = now.toLocaleDateString('en-US', headerDateOptions);
                if (headerTime) headerTime.textContent = now.toLocaleTimeString('en-US', headerTimeOptions);
            } catch (e) {
                console.error('Date update error:', e);
            }
        }

        // ==================== LOAD DASHBOARD STATS ====================
        async function loadDashboardStats() {
            try {
                // Show loading skeletons
                document.querySelectorAll('.stat-number, .badge, .module-stats span, [id$="Count"]').forEach(el => {
                    el.classList.add('skeleton');
                });
                
                const response = await fetch('/api/admin/dashboard/stats', { 
                    credentials: 'include',
                    headers: {
                        'Cache-Control': 'no-cache'
                    }
                });
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const data = await response.json();
                
                if (data.success) {
                    const stats = data.stats || {};
                    
                    // Get user count in parallel
                    let userCount = 0;
                    try {
                        const userResponse = await fetch('/api/admin/users', { 
                            credentials: 'include',
                            headers: { 'Cache-Control': 'no-cache' }
                        });
                        const userData = await userResponse.json();
                        userCount = userData.success && userData.users ? userData.users.length : 
                                   stats.total_users || 0;
                    } catch (e) {
                        console.warn('Could not fetch users:', e);
                        userCount = stats.total_users || 0;
                    }
                    
                    // Update all stat elements
                    const updates = {
                        'totalTravelers': stats.total_travelers || 0,
                        'activeBatches': stats.active_batches || 0,
                        'totalCollections': '₹' + (stats.total_collected || 0).toLocaleString(),
                        'pendingPayments': '₹' + (stats.pending_amount || 0).toLocaleString(),
                        'travelerCount': stats.total_travelers || 0,
                        'batchCount': stats.total_batches || 0,
                        'paymentCount': stats.paid_count || 0,
                        'invoiceCount': 0,
                        'receiptCount': stats.paid_count || 0,
                        'userCount': userCount
                    };
                    
                    // Apply updates
                    Object.entries(updates).forEach(([id, value]) => {
                        const el = document.getElementById(id);
                        if (el) el.textContent = value;
                    });
                    
                    // Update module stats
                    const moduleTraveler = document.querySelector('.module-traveler-count');
                    const moduleBatch = document.querySelector('.module-batch-count');
                    const modulePayment = document.querySelector('.module-payment-count');
                    const moduleInvoice = document.querySelector('.module-invoice-count');
                    const moduleReceipt = document.querySelector('.module-receipt-count');
                    const moduleUser = document.querySelector('.module-user-count');
                    
                    if (moduleTraveler) moduleTraveler.textContent = stats.total_travelers || 0;
                    if (moduleBatch) moduleBatch.textContent = stats.total_batches || 0;
                    if (modulePayment) modulePayment.textContent = stats.paid_count || 0;
                    if (moduleInvoice) moduleInvoice.textContent = '0';
                    if (moduleReceipt) moduleReceipt.textContent = stats.paid_count || 0;
                    if (moduleUser) moduleUser.textContent = userCount;
                    
                    // Remove skeletons
                    document.querySelectorAll('.stat-number, .badge, .module-stats span, [id$="Count"]').forEach(el => {
                        el.classList.remove('skeleton');
                    });
                    
                    console.log('✅ Dashboard stats loaded:', { 
                        users: userCount,
                        travelers: stats.total_travelers,
                        batches: stats.total_batches,
                        payments: stats.paid_count
                    });
                }
            } catch (error) {
                console.error('❌ Error loading dashboard stats:', error);
                showNotification('Error loading dashboard data', 'error');
            }
        }

        // ==================== CHARTS ====================
        function initializeCharts() {
            try {
                // Destroy existing charts
                if (chartInstances.paymentsChart) {
                    chartInstances.paymentsChart.destroy();
                    chartInstances.paymentsChart = null;
                }
                
                if (chartInstances.travelersChart) {
                    chartInstances.travelersChart.destroy();
                    chartInstances.travelersChart = null;
                }
                
                // Use requestAnimationFrame for smoother rendering
                window.requestAnimationFrame(() => {
                    // Payments Chart (Pie)
                    const paymentsCanvas = document.getElementById('paymentsChart');
                    if (paymentsCanvas && typeof Chart !== 'undefined') {
                        const paymentsCtx = paymentsCanvas.getContext('2d');
                        
                        chartInstances.paymentsChart = new Chart(paymentsCtx, {
                            type: 'doughnut',
                            data: {
                                labels: ['Bank Transfer', 'UPI', 'Cash', 'Credit Card', 'Cheque'],
                                datasets: [{
                                    data: [45, 25, 15, 10, 5],
                                    backgroundColor: [
                                        '#3498db',
                                        '#2ecc71',
                                        '#f1c40f',
                                        '#e74c3c',
                                        '#9b59b6'
                                    ],
                                    borderWidth: 0
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: {
                                        position: 'bottom',
                                        labels: {
                                            font: { family: 'Inter', size: 12 }
                                        }
                                    }
                                },
                                cutout: '60%'
                            }
                        });
                    }

                    // Travelers Chart (Bar)
                    const travelersCanvas = document.getElementById('travelersChart');
                    if (travelersCanvas && typeof Chart !== 'undefined') {
                        const travelersCtx = travelersCanvas.getContext('2d');
                        
                        chartInstances.travelersChart = new Chart(travelersCtx, {
                            type: 'bar',
                            data: {
                                labels: ['Haj Platinum', 'Haj Gold', 'Haj Silver', 'Umrah Ramadhan', 'Umrah Winter'],
                                datasets: [{
                                    label: 'Number of Travelers',
                                    data: [45, 82, 120, 170, 140],
                                    backgroundColor: '#3498db',
                                    borderRadius: 8
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: { display: false }
                                },
                                scales: {
                                    y: {
                                        beginAtZero: true,
                                        grid: { display: false }
                                    },
                                    x: {
                                        grid: { display: false }
                                    }
                                }
                            }
                        });
                    }
                });
            } catch (e) {
                console.error('Chart initialization error:', e);
            }
        }

        // ==================== RECENT ACTIVITY ====================
        async function loadRecentActivity() {
            try {
                const response = await fetch('/api/admin/dashboard/stats', { 
                    credentials: 'include',
                    headers: { 'Cache-Control': 'no-cache' }
                });
                
                const data = await response.json();
                const activityList = document.getElementById('recentActivity');
                
                if (!activityList) return;
                
                if (data.success) {
                    const activities = [];
                    
                    // Add recent travelers
                    if (data.recent_travelers && data.recent_travelers.length > 0) {
                        data.recent_travelers.slice(0, 2).forEach(t => {
                            activities.push({
                                type: 'traveler',
                                icon: 'fa-user-plus',
                                color: 'traveler',
                                text: `New traveler: ${t.first_name || ''} ${t.last_name || ''}`.trim(),
                                details: t.passport_no ? `Passport: ${t.passport_no}` : '',
                                time: t.created_at ? new Date(t.created_at).toLocaleString() : 'Just now'
                            });
                        });
                    }
                    
                    // Add recent payments
                    if (data.recent_payments && data.recent_payments.length > 0) {
                        data.recent_payments.slice(0, 2).forEach(p => {
                            activities.push({
                                type: 'payment',
                                icon: 'fa-credit-card',
                                color: 'payment',
                                text: `Payment: ${p.first_name || ''} ${p.last_name || ''}`.trim(),
                                amount: p.amount ? `₹${p.amount.toLocaleString()}` : '',
                                time: p.payment_date ? new Date(p.payment_date).toLocaleString() : 'Just now'
                            });
                        });
                    }
                    
                    // Add upcoming batches
                    if (data.upcoming_batches && data.upcoming_batches.length > 0) {
                        data.upcoming_batches.slice(0, 1).forEach(b => {
                            activities.push({
                                type: 'batch',
                                icon: 'fa-layer-group',
                                color: 'batch',
                                text: `Batch: ${b.batch_name || ''}`,
                                details: b.booked_seats ? `Seats: ${b.booked_seats}/${b.total_seats || 0}` : '',
                                time: b.departure_date ? `Departs: ${new Date(b.departure_date).toLocaleDateString()}` : ''
                            });
                        });
                    }
                    
                    if (activities.length === 0) {
                        activityList.innerHTML = '<div class="activity-item"><div class="activity-details"><p>No recent activity</p></div></div>';
                        return;
                    }
                    
                    // Build HTML efficiently
                    let html = '';
                    for (let i = 0; i < Math.min(5, activities.length); i++) {
                        const a = activities[i];
                        html += '<div class="activity-item">' +
                            '<div class="activity-icon ' + a.color + '">' +
                                '<i class="fas ' + a.icon + '"></i>' +
                            '</div>' +
                            '<div class="activity-details">' +
                                '<p>' + a.text + (a.amount ? ' <span class="activity-amount">' + a.amount + '</span>' : '') + '</p>' +
                                '<small><i class="fas fa-clock"></i> ' + a.time + (a.details ? ' • ' + a.details : '') + '</small>' +
                            '</div>' +
                        '</div>';
                    }
                    
                    activityList.innerHTML = html;
                }
            } catch (error) {
                console.error('Error loading activity:', error);
            }
        }

        // ==================== LOGOUT ====================
        async function logout() {
            if (confirm('Are you sure you want to logout?')) {
                await SessionManager.logout();
            }
        }

        // ==================== NOTIFICATION ====================
        function showNotification(message, type = 'success') {
            const notification = document.getElementById('notification');
            if (!notification) return;
            
            const icon = type === 'success' ? 'check-circle' : 
                        type === 'error' ? 'exclamation-circle' : 
                        type === 'warning' ? 'exclamation-triangle' : 'info-circle';
            
            notification.className = `notification notification-${type}`;
            notification.innerHTML = `<i class="fas fa-${icon}"></i> ${message}`;
            notification.style.display = 'block';
            
            // Clear existing timeout
            if (notificationTimeout) {
                clearTimeout(notificationTimeout);
            }
            
            notificationTimeout = setTimeout(() => {
                notification.style.display = 'none';
            }, 3000);
        }

        // ==================== HELPER FUNCTIONS ====================
        function formatRole(role) {
            try {
                if (!role) return 'Administrator';
                return role.split('_').map(word => 
                    word.charAt(0).toUpperCase() + word.slice(1)
                ).join(' ');
            } catch (e) {
                return role || 'Administrator';
            }
        }

        // ==================== CHART PERIOD CHANGE ====================
        document.addEventListener('DOMContentLoaded', function() {
            const paymentSelect = document.getElementById('paymentChartPeriod');
            const travelersSelect = document.getElementById('travelersChartPeriod');
            
            if (paymentSelect) {
                paymentSelect.addEventListener('change', (e) => {
                    showNotification(`Updating payment chart for ${e.target.value}`, 'info');
                    // Here you would update the chart with real data
                });
            }

            if (travelersSelect) {
                travelersSelect.addEventListener('change', (e) => {
                    showNotification(`Updating travelers chart for ${e.target.value}`, 'info');
                    // Here you would update the chart with real data
                });
            }
        });
    </script>
</body>
</html>
