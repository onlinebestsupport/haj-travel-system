            # Recent payments (last 5)
            cursor.execute('''
                SELECT p.id, p.amount, p.payment_date, t.first_name, t.last_name
                FROM payments p
                JOIN travelers t ON p.traveler_id = t.id
                ORDER BY p.payment_date DESC LIMIT 5
            ''')
