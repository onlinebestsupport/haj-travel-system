            # Upcoming batches (next 3)
            cursor.execute('''
                SELECT id, batch_name, departure_date, total_seats, booked_seats
                FROM batches WHERE departure_date > NOW()
                ORDER BY departure_date ASC LIMIT 3
            ''')
