<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Management - Alhudha Haj Admin</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background: #f5f7fa; }
        .container { max-width: 1400px; margin: 0 auto; padding: 20px; }
        
        .admin-header {
            background: linear-gradient(135deg, #2c3e50, #34495e);
            color: white;
            padding: 15px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 20px;
        }
        .logo-area { display: flex; align-items: center; gap: 15px; }
        .logo-area i { font-size: 2rem; color: #f1c40f; }
        .role-badge {
            background: #f1c40f;
            color: #2c3e50;
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: bold;
        }
        .logout-btn {
            background: #e74c3c;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 5px;
            cursor: pointer;
        }
        
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 30px 0 20px;
        }
        
        .table-container {
            background: white;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            overflow-x: auto;
            margin-top: 20px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th {
            background: #2c3e50;
            color: white;
            padding: 15px;
            text-align: left;
        }
        td {
            padding: 15px;
            border-bottom: 1px solid #ecf0f1;
        }
        tr:hover { background: #f8f9fa; }
        
        .role-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: bold;
            color: white;
            display: inline-block;
        }
        .role-super_admin { background: #8e44ad; }
        .role-admin { background: #3498db; }
        .role-manager { background: #f39c12; }
        .role-staff { background: #27ae60; }
        .role-viewer { background: #7f8c8d; }
        
        .status-active {
            background: #d4edda;
            color: #155724;
            padding: 4px 12px;
            border-radius: 20px;
        }
        
        .loading { text-align: center; padding: 40px; color: #7f8c8d; }
        .loading i { animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        
        .action-btn {
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            background: #3498db;
            color: white;
        }
        .icon-btn {
            background: none;
            border: none;
            color: #3498db;
            cursor: pointer;
            font-size: 1.2rem;
            margin: 0 5px;
        }
    </style>
    <script src="/admin/js/session-manager.js"></script>
</head>
<body>
    <div class="admin-header">
        <div class="header-content">
            <div class="logo-area">
                <i class="fas fa-kaaba"></i>
                <h1>Alhudha Haj Admin - User Management</h1>
                <span class="role-badge" id="roleBadge">Loading...</span>
            </div>
            <div>
                <a href="dashboard.html" class="action-btn">Dashboard</a>
                <button onclick="logout()" class="logout-btn">Logout</button>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="page-header">
            <h2><i class="fas fa-users-cog"></i> User Management</h2>
        </div>

        <div class="table-container">
            <table id="usersTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Username</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Last Login</th>
                    </tr>
                </thead>
                <tbody id="usersTableBody">
                    <tr><td colspan="7" class="loading"><i class="fas fa-spinner fa-spin"></i> Loading users...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        // Simple working version
        async function loadUsers() {
            const tbody = document.getElementById('usersTableBody');
            
            try {
                const response = await fetch('/api/admin/users', {
                    credentials: 'include'
                });
                
                if (response.status === 401) {
                    window.location.href = '/admin.login.html';
                    return;
                }
                
                const data = await response.json();
                
                if (data.success && data.users) {
                    let html = '';
                    data.users.forEach(user => {
                        const roleClass = 'role-' + (user.role || 'staff');
                        html += `<tr>
                            <td>${user.id}</td>
                            <td><strong>${user.username}</strong></td>
                            <td>${user.full_name || '-'}</td>
                            <td>${user.email}</td>
                            <td><span class="role-badge ${roleClass}">${user.role || 'staff'}</span></td>
                            <td><span class="status-active">${user.is_active ? 'Active' : 'Inactive'}</span></td>
                            <td>${user.last_login ? new Date(user.last_login).toLocaleString() : 'Never'}</td>
                        </tr>`;
                    });
                    tbody.innerHTML = html;
                }
            } catch (error) {
                console.error('Error loading users:', error);
                tbody.innerHTML = '<tr><td colspan="7" style="color: red; text-align: center;">Error loading users</td></tr>';
            }
        }

        async function logout() {
            if (typeof SessionManager !== 'undefined') {
                await SessionManager.logout();
            } else {
                await fetch('/api/logout', { method: 'POST', credentials: 'include' });
                window.location.href = '/admin.login.html';
            }
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', async function() {
            if (typeof SessionManager !== 'undefined') {
                await SessionManager.initPage(loadUsers);
            } else {
                // Fallback session check
                try {
                    const res = await fetch('/api/check-session', { credentials: 'include' });
                    const data = await res.json();
                    if (data.authenticated) {
                        document.getElementById('roleBadge').textContent = data.user.role.toUpperCase();
                        await loadUsers();
                    } else {
                        window.location.href = '/admin.login.html';
                    }
                } catch (e) {
                    window.location.href = '/admin.login.html';
                }
            }
        });
    </script>
</body>
</html>